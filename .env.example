# ===============================
# FinanceTracker configuration
# ===============================
# 1) Copy this file to .env
# 2) Replace CHANGE_ME values
# 3) Start the stack from repository root:
#    docker compose up -d --build
#
# Important:
# - compose.yml in the repository root is the primary entrypoint
# - bot auto messages at 18:00 use container local time
# - TIMEZONE only affects text rendering and part of the bot date calculations

# --- Postgres / Docker Compose ---
POSTGRES_DB=fintracker
POSTGRES_USER=aqua4
POSTGRES_PASSWORD=CHANGE_ME

# --- Direct app DB settings ---
# Under the default Docker Compose flow these values are overridden by compose.yml:
# DB_HOST=db, DB_PORT=5432, DB_NAME=${POSTGRES_DB}, DB_USER=${POSTGRES_USER},
# DB_PASSWORD=${POSTGRES_PASSWORD}.
# Keep them here for direct runs outside Docker or for explicit documentation.
DB_HOST=db
DB_PORT=5432
DB_NAME=fintracker
DB_USER=aqua4
DB_PASSWORD=CHANGE_ME

# Optional DSN override for tracker and bot.
# If set, DB_DSN wins over DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD inside the apps.
# DB_DSN=postgresql+psycopg2://aqua4:CHANGE_ME@db:5432/fintracker

# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Telegram user IDs allowed to use the bot and receive auto-messages
ALLOWED_USER_IDS=365469,428849549

# --- Bot time / scheduling ---
# Used by bot text rendering and part of bot local date calculations
TIMEZONE=Europe/Moscow

# --- Tracker time / scheduling ---
# Used by tracker scheduler and snapshot_date
SCHED_TZ=Europe/Moscow

# interval | cron
SNAPSHOT_MODE=interval

# Used when SNAPSHOT_MODE=interval
SNAPSHOT_INTERVAL_MINUTES=5

# Used when SNAPSHOT_MODE=cron
SNAPSHOT_HOUR=23
SNAPSHOT_MINUTE=30

# Optional one-time JobQueue smoke-test on bot startup
JOBQUEUE_SMOKE_TEST_ON_START=false
JOBQUEUE_SMOKE_TEST_DELAY_SECONDS=20

# --- Portfolio / plan settings ---
ACCOUNT_FRIENDLY_NAME=Семейный капитал
PLAN_ANNUAL_CONTRIB_RUB=400000

# --- T-Invest API ---
TINVEST_API_TOKEN=CHANGE_ME
TINVEST_BASE_URL=https://invest-public-api.tbank.ru/rest
TINVEST_PORTFOLIO_CURRENCY=RUB
TINVEST_ACCOUNT_STATUS=ACCOUNT_STATUS_ALL

# Exact account id from API. "auto" means "do not force a match" in current code path.
TINKOFF_ACCOUNT_ID=auto

# Safety guard for paginated operation sync
OPERATIONS_MAX_PAGES=10000

# --- HTTP ---
VERIFY_SSL=false

# --- Logging / service identity ---
APP_ENV=dev
APP_SERVICE_TRACKER=iis_tracker
APP_SERVICE_BOT=iis_tracker_bot
LOG_LEVEL=INFO
