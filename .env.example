# ===============================
# FinanceTracker configuration
# ===============================
# 1) Copy this file to .env
# 2) Replace CHANGE_ME values
# 3) Start the stack (from project root):
#    docker compose --project-directory . -f .\docker\compose.yml up -d --build

# --- Postgres ---
POSTGRES_DB=fintracker
POSTGRES_USER=aqua4
POSTGRES_PASSWORD=CHANGE_ME

# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Restrict who can use the bot (Telegram user IDs, comma-separated)
ALLOWED_USER_IDS=365469,428849549

# --- Scheduling (all notifications at 18:00 by default) ---
TIMEZONE=Europe/Moscow
DAILY_SUMMARY_HOUR=18
DAILY_SUMMARY_MINUTE=0

# --- Portfolio / plan settings ---
ACCOUNT_FRIENDLY_NAME=Семейный капитал
PLAN_ANNUAL_CONTRIB_RUB=400000
DRAWDOWN_ALERT_PCT=5.0

# --- T-Invest API ---
TINVEST_API_TOKEN=CHANGE_ME
TINVEST_BASE_URL=https://invest-public-api.tbank.ru/rest
TINVEST_PORTFOLIO_CURRENCY=RUB
TINVEST_ACCOUNT_STATUS=ACCOUNT_STATUS_ALL

# Optional: set exact account id from API. Use "auto" to pick the first available.
TINKOFF_ACCOUNT_ID=auto

# Operations sync safety limit
OPERATIONS_MAX_PAGES=10000

# --- HTTP ---
VERIFY_SSL=false

# --- Snapshots ---
# How often to save portfolio snapshot (minutes)
SNAPSHOT_INTERVAL_MINUTES=5

# Compatibility (may be unused depending on tracker logic)
SNAPSHOT_HOUR=23
SNAPSHOT_MINUTE=30
